generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  tasks     Task[]
  cycles    Cycle[]
  lists     List[]
  createdAt DateTime @default(now())
}

model Task {
  id          String   @id
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payload     Json
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model Cycle {
  id          String   @id
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payload     Json
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model List {
  id          String   @id
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payload     Json
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}
